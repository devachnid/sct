# Copy to .env and fill in your NHS TRUD API key.
# Your TRUD account must be subscribed to the selected edition.
TRUD_API_KEY=

# Defaults are suitable for a UK VPS terminology server.
# SCT_TRUD_EDITION=uk_monolith
# SCT_REFSETS=all
# SCT_LOCALE=en-GB

# Set to true if you want inactive concepts retained in the served database.
# SCT_INCLUDE_INACTIVE=false

# --- TLS (Caddy) ---
# Your public hostname, DNS already pointing at this server. Caddy provisions
# HTTPS automatically via Let's Encrypt when this is set. Leave unset for
# plain HTTP on :80 (local/dev, or behind another TLS-terminating proxy).
# DOMAIN=fhir.example.org

# Let's Encrypt account email - not required, but you'll get cert-expiry
# notices sent to it.
# ACME_EMAIL=you@example.org

# --- Optional basic auth ---
# Terminology data is non-PHI and read-only, so this is opt-in - mainly abuse
# control on a publicly reachable endpoint. Both must be set for auth to
# apply; leave both unset for no auth. Generate the hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# BASIC_AUTH_USER=
# BASIC_AUTH_HASH=

# Allowed CORS origins for browser-based FHIR clients.
# CORS_ORIGINS=*
