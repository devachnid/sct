# Copy to .env and fill in your NHS TRUD API key.
# Your TRUD account must be subscribed to the selected edition.
TRUD_API_KEY=

# Defaults are suitable for a UK VPS terminology server.
# SCT_TRUD_EDITION=uk_monolith
# SCT_REFSETS=all
# SCT_LOCALE=en-GB
# SCT_PORT=8080

# Set to true if you want inactive concepts retained in the served database.
# SCT_INCLUDE_INACTIVE=false
