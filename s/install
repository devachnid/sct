#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 Marcus Baw and Baw Medical Ltd
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Install the local build onto the user's PATH (cargo install --path .).
# Pass feature flags to opt in to the gated subcommands (see Cargo.toml):
#
#   --serve   sct serve   - FHIR R4 terminology server
#   --tui     sct tui     - terminal UI
#   --gui     sct gui      - browser UI
#   --dmwb    sct dmwb     - NHS Data Migration Workbench .mdb reader
#   --full    tui + gui + serve (does not include dmwb)
#
# Combine as needed, e.g.  s/install --serve --tui  or  s/install --full --dmwb

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

features=()
for arg in "$@"; do
  case "$arg" in
    --serve) features+=("serve") ;;
    --tui)   features+=("tui") ;;
    --gui)   features+=("gui") ;;
    --dmwb)  features+=("dmwb") ;;
    --full)  features+=("full") ;;
    -h|--help) sed -n '5,15p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "Unknown option: $arg (try: --serve --tui --gui --dmwb --full)" >&2; exit 1 ;;
  esac
done

if [[ ${#features[@]} -gt 0 ]]; then
  feature_list=$(IFS=,; echo "${features[*]}")
  exec cargo install --path . --features "$feature_list"
else
  exec cargo install --path .
fi
